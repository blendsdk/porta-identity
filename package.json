{
  "name": "root",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "nohoist": [
      "**/glob/**"
    ]
  },
  "engines": {
    "node": ">=10.15.0",
    "yarn": ">=1.5.1"
  },
  "scripts": {
    "tag-version-auto": "lerna version --no-changelog --conventional-commits --yes",
    "publish-packages": "lerna publish from-package",
    "postinstall": "rm -fR ./node_modules/@types/eslint-scope &&  rm -fR node_modules/@types/cacheable-request",
    "bootstrap": "lerna bootstrap --use-workspaces",
    "build": "lerna clean -y && lerna run build",
    "test": "jest jest --clearCache && lerna run --scope=@porta/webapi test",
    "ncu": "ncu -u -x chalk,nanoid,\"@blendsdk*\",\"@porta*\" && lerna exec \"ncu -u -x chalk,nanoid,'@blendsdk*','@porta*' \" && rm -fR node_modules yarn.lock && yarn install && yarn bootstrap && yarn build && yarn test",
    "generate": "lerna run generate --scope=@porta/codegen && lerna run build --scope=@porta/shared",
    "blend:next": "`pwd`/scripts/blend-update.js next > ./blend-update-gen.sh && chmod +x ./blend-update-gen.sh && ./blend-update-gen.sh && rm ./blend-update-gen.sh && yarn remove -W glob && yarn -W add glob",
    "blend:stable": "`pwd`/scripts/blend-update.js stable > ./blend-update-gen.sh && chmod +x ./blend-update-gen.sh && ./blend-update-gen.sh && rm ./blend-update-gen.sh",
    "blend:develop": "`pwd`/scripts/blend-update.js develop > ./blend-update-gen.sh && chmod +x ./blend-update-gen.sh && ./blend-update-gen.sh && rm ./blend-update-gen.sh",
    "dev": "nodemon --verbose --delay 2.5 --watch ./packages/codegen/src --watch ./scripts --ext ts `pwd`/scripts/dev.sh"
  },
  "devDependencies": {
    "@jest/core": "^29.5.0",
    "@jest/reporters": "^29.5.0",
    "@types/jest": "^29.4.1",
    "@types/node": "^18.15.3",
    "concurrently": "^7.6.0",
    "jest": "^29.5.0",
    "jest-cli": "^29.5.0",
    "jest-watch-typeahead": "^2.2.2",
    "lerna": "^6.5.1",
    "nodemon": "^2.0.21",
    "npm-check-updates": "^16.7.12",
    "react-dropzone": "^14.2.3",
    "ts-jest": "^29.0.5",
    "typescript": "^4.9.5",
    "zustand": "^4.3.6"
  },
  "dependencies": {
    "glob": "^9.3.2",
    "remove": "^0.1.5"
  }
}
