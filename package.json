{
  "name": "porta",
  "version": "0.1.0",
  "description": "Multi-tenant OIDC provider built on node-oidc-provider + Koa + TypeScript",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "kill": "fuser -k 3000/tcp 2>/dev/null || true",
    "dev": "yarn kill && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run --project unit --project integration",
    "test:all": "vitest run --project unit --project integration --project e2e --project pentest",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:pentest": "vitest run --project pentest",
    "test:ui": "npx playwright test --config tests/ui/playwright.config.ts",
    "test:ui:debug": "npx playwright test --config tests/ui/playwright.config.ts --headed --workers=1",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "verify": "yarn lint && yarn build && yarn test",
    "migrate": "node-pg-migrate up --migrations-dir migrations --migration-file-language sql",
    "migrate:rollback": "node-pg-migrate down --migrations-dir migrations --migration-file-language sql --count 1",
    "migrate:status": "node-pg-migrate status --migrations-dir migrations --migration-file-language sql",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations --migration-file-language sql",
    "porta": "tsx src/cli/index.ts",
    "playground": "bash scripts/run-playground.sh",
    "playground:stop": "bash scripts/run-playground-stop.sh",
    "playground:reset": "bash scripts/run-playground-reset.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deps:check": "ncu",
    "deps:update": "ncu -u && yarn install"
  },
  "bin": {
    "porta": "./dist/cli/index.js"
  },
  "dependencies": {
    "@koa/router": "15.4.0",
    "argon2": "0.44.0",
    "chalk": "5.3.0",
    "cli-table3": "0.6.5",
    "dotenv": "17.4.1",
    "handlebars": "4.7.9",
    "i18next": "26.0.4",
    "i18next-fs-backend": "2.6.3",
    "ioredis": "5.10.1",
    "jose": "6.2.2",
    "koa": "3.2.0",
    "koa-bodyparser": "4.4.1",
    "node-pg-migrate": "8.0.4",
    "nodemailer": "8.0.5",
    "oidc-provider": "9.8.0",
    "open": "11.0.0",
    "otpauth": "9.5.0",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "prom-client": "^15",
    "qrcode": "1.5.4",
    "yargs": "17.7.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@types/koa": "3.0.2",
    "@types/koa-bodyparser": "4.3.13",
    "@types/koa__router": "12.0.5",
    "@types/node": "25.6.0",
    "@types/nodemailer": "8.0.0",
    "@types/oidc-provider": "9.5.0",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/yargs": "17.0.33",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "mermaid": "11.14.0",
    "npm-check-updates": "20.0.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.7",
    "vitepress": "1.6.4",
    "vitepress-plugin-mermaid": "2.0.17",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
