{
  "name": "root",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "engines": {
    "node": ">=10.15.0",
    "yarn": ">=1.5.1"
  },
  "scripts": {
    "tag-version-auto": "lerna version --no-changelog --conventional-commits --yes",
    "tag-version-pre": "lerna version patch --no-changelog --include-merged-tags --force-publish --exact",
    "publish-packages": "lerna publish from-package",
    "postinstall": "rm -fR ./node_modules/@types/eslint-scope &&  rm -fR node_modules/@types/cacheable-request",
    "build": "lerna clean -y && lerna run build",
    "test": "jest jest --clearCache && lerna run --scope=@porta/webapi test",
    "ncu": "ncu -u -x scheduler,chalk,nanoid,\"@blendsdk*\",\"@porta*\" && lerna exec \"ncu -u -x chalk,nanoid,'@blendsdk*','@porta*' \" && rm -fR node_modules yarn.lock && yarn install && yarn build && yarn test",
    "generate": "lerna run generate --scope=@porta/codegen && lerna run build --scope=@porta/shared",
    "blend:next": "`pwd`/scripts/blend-update.js next > ./blend-update-gen.sh && chmod +x ./blend-update-gen.sh && ./blend-update-gen.sh && rm ./blend-update-gen.sh",
    "blend:stable": "`pwd`/scripts/blend-update.js stable > ./blend-update-gen.sh && chmod +x ./blend-update-gen.sh && ./blend-update-gen.sh && rm ./blend-update-gen.sh",
    "blend:develop": "`pwd`/scripts/blend-update.js develop > ./blend-update-gen.sh && chmod +x ./blend-update-gen.sh && ./blend-update-gen.sh && rm ./blend-update-gen.sh"
  },
  "devDependencies": {
    "@jest/core": "^29.7.0",
    "@jest/reporters": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.4",
    "concurrently": "^9.0.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "lerna": "^8.1.8",
    "nodemon": "^3.1.4",
    "npm-check-updates": "^17.1.1",
    "react-dropzone": "^14.2.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "remove": "^0.1.5",
    "ts-node": "^10.9.2"
  }
}