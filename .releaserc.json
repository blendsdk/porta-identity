{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/sync-versions.js ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "pkgRoot": "packages/porta-sdk"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "pkgRoot": "packages/porta-cli"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "pkgRoot": "packages/porta-admin-gui"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "packages/porta-sdk/package.json",
          "packages/porta-cli/package.json",
          "packages/porta-admin-gui/package.json",
          "packages/porta-sdk/src/version.ts",
          "packages/porta-cli/src/commands/version.ts",
          "packages/porta-admin-gui/src/version.ts"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
