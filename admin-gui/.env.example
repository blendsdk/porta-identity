# Porta Admin GUI — BFF Configuration
# Copy to .env and fill in values

# Required: URL of the Porta server (internal network in Docker, localhost in dev)
PORTA_ADMIN_PORTA_URL=http://localhost:3000

# Required: OIDC client credentials (from `porta init` output)
PORTA_ADMIN_CLIENT_ID=
PORTA_ADMIN_CLIENT_SECRET=

# Required: Session encryption key (min 32 characters)
PORTA_ADMIN_SESSION_SECRET=

# Required: Redis URL for session storage
REDIS_URL=redis://localhost:6379/1

# Optional: BFF listen port (default: 4002)
PORTA_ADMIN_PORT=4002

# Optional: Public URL for OIDC redirect URIs (default: http://localhost:4002)
PORTA_ADMIN_PUBLIC_URL=http://localhost:4002

# Optional: Super-admin org slug (default: auto-detected from Porta metadata)
PORTA_ADMIN_ORG_SLUG=

# Optional: Environment (production/development/test)
NODE_ENV=development

# Optional: Log level (debug/info/warn/error)
LOG_LEVEL=info
