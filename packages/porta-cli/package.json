{
  "name": "@portaidentity/cli",
  "version": "0.1.0",
  "description": "Standalone CLI for the Porta Identity Platform",
  "type": "module",
  "bin": {
    "porta": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "verify": "yarn lint && yarn typecheck && yarn test && yarn build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@portaidentity/sdk": "0.1.0",
    "chalk": "^5.0.0",
    "cli-table3": "^0.6.0",
    "jose": "^6.2.3",
    "open": "^11.0.0",
    "yaml": "^2.8.4",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
