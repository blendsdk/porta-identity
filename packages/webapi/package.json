{
    "name": "@porta/webapi",
    "version": "1.0.214",
    "main": "dist/index.js",
    "private": true,
    "bin": {
        "porta-ctrl": "./dist/index.js"
    },
    "author": "TrueSoftware <info@truesoftware.nl>",
    "scripts": {
        "dev": "rm -fR ./dist && NODE_TLS_REJECT_UNAUTHORIZED=0 DEBUG=true nodemon --verbose --config ./nodemon.json ./src/index.ts start --config=`pwd`/config/*.config.js",
        "build": "rm -fR ./dist ./temp && tsc",
        "watch:ts": "rm -fR ./dist && tsc -w",
        "watch:node": "NODE_TLS_REJECT_UNAUTHORIZED=0 XBYPASS=true DEBUG=true nodemon --config ./nodemon.json --watch ./dist/ --watch ./resources/ --watch ./config/ --inspect ./dist/index.js start --config=`pwd`/config/*.config.js --config=`pwd`/config/.*.config.js --migrate=${MIGRATE:-false}",
        "watch:node:oidc": "BYPASS=true DEBUG=true nodemon --config ./nodemon.json --watch ./dist/ --watch ./resources/ --watch ./config-oidc/ --inspect ./dist/index.js start --config=`pwd`/config-oidc/*.config.js --config=`pwd`/config-oidc/.*.config.js --oidcRedirectUri=\"https://localhost.emobix.co.uk:8443/test/a/oidc_suite/callback\"",
        "db:start": "docker-compose -f ./docker/docker-compose.yml up -d db && ./wait-for 127.0.0.1:5010",
        "db:stop": "docker-compose -f ./docker/docker-compose.yml rm -fsv db && docker container prune --force",
        "db:restart": "yarn db:stop && yarn db:start",
        "test": "yarn cache:restart && yarn db:restart && sleep 30 && BYPASS=true TEST=true jest --detectOpenHandles --passWithNoTests && yarn db:stop",
        "test:fast": "BYPASS=true TEST=true jest --passWithNoTests --detectOpenHandles",
        "cache:start": "docker-compose -f ./docker/docker-compose.yml up -d redis",
        "cache:stop": "docker-compose -f ./docker/docker-compose.yml rm -fsv redis && docker container prune --force",
        "cache:restart": "yarn cache:stop && sleep 5 && yarn cache:start"
    },
    "dependencies": {
        "@blendsdk/clientkit": "3.2.338",
        "@blendsdk/crypto": "3.2.338",
        "@blendsdk/datakit": "3.2.338",
        "@blendsdk/expression": "3.2.338",
        "@blendsdk/jsonschema": "3.2.338",
        "@blendsdk/postgresql": "3.2.338",
        "@blendsdk/rbac": "3.2.338",
        "@blendsdk/stdlib": "3.2.338",
        "@blendsdk/webafx": "3.2.338",
        "@blendsdk/webafx-auth": "3.2.338",
        "@blendsdk/webafx-auth-oidc": "3.2.338",
        "@blendsdk/webafx-cache-redis": "3.2.338",
        "@blendsdk/webafx-common": "3.2.338",
        "@blendsdk/webafx-i18n": "3.2.338",
        "@blendsdk/webafx-mailer": "3.2.338",
        "@peculiar/webcrypto": "^1.4.3",
        "@peculiar/x509": "^1.9.5",
        "@porta/shared": "1.0.214",
        "@types/jsonwebtoken": "^9.0.3",
        "dayjs": "^1.11.10",
        "jose": "^4.15.1",
        "jsonwebtoken": "^9.0.2",
        "openid-client": "^5.5.0",
        "tslib": "^2.6.2",
        "yargs": "^17.7.2"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.3"
    }
}
