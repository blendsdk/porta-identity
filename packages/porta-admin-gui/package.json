{
  "name": "@portaidentity/admin-gui",
  "version": "0.1.0",
  "description": "Standalone Admin GUI for Porta Identity — React SPA + Koa BFF",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "porta-gui": "dist/bin.js"
  },
  "files": [
    "dist/",
    "public/"
  ],
  "scripts": {
    "build": "vite build && tsc --project tsconfig.json",
    "build:client": "vite build",
    "build:server": "tsc --project tsconfig.json",
    "dev": "tsx watch src/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.56.8",
    "@fluentui/react-icons": "^2.0.275",
    "koa": "^2.15.4",
    "koa-mount": "^4.0.0",
    "koa-static": "^5.0.0",
    "openid-client": "^6.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa-mount": "^4.0.5",
    "@types/koa-static": "^4.0.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  },
  "peerDependencies": {
    "@portaidentity/sdk": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@portaidentity/sdk": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blendsdk/porta-identity.git",
    "directory": "packages/porta-admin-gui"
  },
  "license": "MIT"
}
