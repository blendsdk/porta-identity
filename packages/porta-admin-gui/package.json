{
  "name": "@portaidentity/admin-gui",
  "version": "1.5.0",
  "description": "Standalone Admin GUI for Porta Identity — React SPA + Koa BFF",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "porta-gui": "dist/bin.js"
  },
  "files": [
    "dist/",
    "public/"
  ],
  "scripts": {
    "build": "yarn build:client && yarn build:server",
    "build:client": "vite build",
    "build:server": "tsc --project tsconfig.json",
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:client\"",
    "dev:server": "tsx watch src/index.ts --server https://porta.local:3443 --port 4003 --public-port 4002 --insecure --no-open",
    "dev:client": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.ts'",
    "verify": "yarn lint && yarn build && yarn test",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-icons": "^2.0.330",
    "@koa/router": "15.6.0",
    "chalk": "^5.6.2",
    "koa": "3.2.1",
    "koa-bodyparser": "4.4.1",
    "koa-mount": "^4.2.0",
    "koa-static": "^5.0.0",
    "open": "^11.0.0",
    "openid-client": "^6.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/koa": "3.0.3",
    "@types/koa-bodyparser": "4.3.13",
    "@types/koa-mount": "^4.0.5",
    "@types/koa-static": "^4.0.4",
    "@types/koa__router": "12.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  },
  "resolutions": {
    "@types/koa": "3.0.3"
  },
  "peerDependencies": {
    "@portaidentity/sdk": "1.5.0"
  },
  "peerDependenciesMeta": {
    "@portaidentity/sdk": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blendsdk/porta-identity.git",
    "directory": "packages/porta-admin-gui"
  },
  "license": "MIT"
}
