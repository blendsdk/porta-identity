{
  "name": "@portaidentity/admin-gui",
  "version": "1.0.0",
  "description": "Standalone Admin GUI for the Porta Identity Platform",
  "type": "module",
  "bin": {
    "porta-gui": "./dist/server/index.js"
  },
  "main": "./dist/server/index.js",
  "exports": {
    ".": "./dist/server/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn build:server && yarn build:client",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'src/**/*.tsx' 'tests/**/*.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "verify": "yarn lint && yarn typecheck && yarn test && yarn build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@portaidentity/sdk": "1.0.0",
    "@koa/router": "^15.0.0",
    "koa": "^3.0.0",
    "koa-bodyparser": "^4.4.0",
    "koa-static": "^5.0.0",
    "openid-client": "^6.0.0",
    "open": "^11.0.0",
    "chalk": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@fluentui/react-components": "^9.0.0",
    "@fluentui/react-icons": "^2.0.0",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.0",
    "@types/koa-static": "^4.0.0",
    "@types/koa__router": "^12.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blendsdk/porta-identity.git",
    "directory": "packages/porta-admin-gui"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
