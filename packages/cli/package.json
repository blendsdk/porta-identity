{
    "name": "@porta/cli",
    "private": true,
    "version": "1.0.245",
    "main": "dist/index.js",
    "bin": {
        "porta-cli": "./dist/index.js"
    },
    "author": "TrueSoftware <info@truesoftware.nl>",
    "scripts": {
        "cli:run": "NODE_TLS_REJECT_UNAUTHORIZED=0 node ./dist/index.js",
        "build": "rm -fR ./dist ./temp && tsc",
        "watch:ts": "rm -fR ./dist && tsc -w",
        "watch:node": "NODE_TLS_REJECT_UNAUTHORIZED=0 BYPASS=true DEBUG=true nodemon --config ./nodemon.json --watch ./dist/ --watch ./resources/ --watch ./config/ --inspect ./dist/index.js start --config=`pwd`/config/*.config.js --config=`pwd`/config/.*.config.js --migrate=${MIGRATE:-false}",
        "test": "NODE_TLS_REJECT_UNAUTHORIZED=0 yarn cache:restart && yarn db:restart && sleep 30 && BYPASS=true TEST=true jest --detectOpenHandles --passWithNoTests && yarn db:stop",
        "build:pkg": "yarn build && mkdir -p ./cli-dist && rm -fR ./cli-dist && npx pkg --target node18-macos-x64 -C GZip -o ./cli-dist/porta-cli ./dist/index.js"
    },
    "dependencies": {
        "@blendsdk/crypto": "3.2.377",
        "@blendsdk/filesystem": "3.2.377",
        "@blendsdk/jsonschema": "3.2.377",
        "@blendsdk/logger": "3.2.377",
        "@blendsdk/stdlib": "3.2.377",
        "@blendsdk/webafx": "3.2.377",
        "@blendsdk/webafx-auth": "3.2.377",
        "@blendsdk/webafx-auth-oidc": "3.2.377",
        "@blendsdk/webafx-cache-memory": "3.2.377",
        "@blendsdk/webafx-common": "3.2.377",
        "@inquirer/password": "^1.1.12",
        "@inquirer/prompts": "^3.1.2",
        "@peculiar/x509": "^1.9.5",
        "@porta/shared": "1.0.245",
        "@types/yargs": "^17.0.26",
        "http-terminator": "^3.2.0",
        "jose": "^4.14.6",
        "jwt-decode": "^3.1.2",
        "tslib": "^2.6.2",
        "yargs": "^17.7.2"
    }
}
