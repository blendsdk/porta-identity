{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach",
            "port": 9229,
            "sourceMaps": true,
            "request": "attach",
            "skipFiles": ["<node_internals>/**"],
            "type": "node"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "WebApi Tests ClientCredentials",
            "env": { "TEST": "true", "BYPASS": true },
            "program": "${workspaceFolder}/node_modules/.bin/jest",
            "args": ["--runInBand", "--detectOpenHandles", "m2m"],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "disableOptimisticBPs": true,
            "sourceMaps": true,
            "cwd": "${workspaceFolder}/packages/webapi",
            "windows": {
                "program": "${workspaceFolder}/node_modules/jest/bin/jest"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "WebApi Tests",
            "env": { "TEST": "true", "BYPASS": true },
            "program": "${workspaceFolder}/node_modules/.bin/jest",
            "args": ["--runInBand", "--detectOpenHandles"],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "disableOptimisticBPs": true,
            "sourceMaps": true,
            "cwd": "${workspaceFolder}/packages/webapi",
            "windows": {
                "program": "${workspaceFolder}/node_modules/jest/bin/jest"
            }
        },
        {
            "type": "node",
            "port": 9229,
            "sourceMaps": true,
            "request": "launch",
            "smartStep": true,
            "name": "WebApi Debug",
            "program": "${workspaceFolder}/packages/webapi/dist/index.js",
            "args": ["start", "--config", "./config/*.config.js"],
            "env": { "BYPASS": true, "NODE_TLS_REJECT_UNAUTHORIZED": "0" },
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "cwd": "${workspaceFolder}/packages/webapi",
            "windows": {
                "program": "--config ${workspaceFolder}/packages/webapu/config/*.config.js"
            },
            "timeout": 5000
        },
        {
            "type": "node",
            "port": 9229,
            "sourceMaps": true,
            "request": "launch",
            "smartStep": true,
            "name": "WebApi OIDC Debug",
            "program": "${workspaceFolder}/packages/webapi/dist/index.js",
            "args": ["start", "--config", "./config-oidc/*.config.js"],
            "env": { "BYPASS": true },
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "cwd": "${workspaceFolder}/packages/webapi",
            "windows": {
                "program": "--config ${workspaceFolder}/packages/webapu/config/*.config.js"
            },
            "timeout": 5000
        }
    ]
}
