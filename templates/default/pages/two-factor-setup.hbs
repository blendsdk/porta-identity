{{!-- Two-factor setup page: TOTP QR code enrollment + recovery codes --}}
<h1>{{t "two-factor.setup_title"}}</h1>
<p class="text-muted mb-4">{{t "two-factor.setup_subtitle"}}</p>

{{> flash-messages}}

<div style="margin-bottom: 24px;">
  <h2 style="font-size: 16px; margin-bottom: 8px;">{{t "two-factor.setup_step1"}}</h2>
  <p style="font-size: 13px; color: #6b7280; margin-bottom: 16px;">{{t "two-factor.setup_scan_instructions"}}</p>

  {{#if qrCodeDataUri}}
  <div style="text-align: center; margin-bottom: 16px;">
    <img src="{{qrCodeDataUri}}" alt="{{t "two-factor.qr_code_alt"}}" style="width: 200px; height: 200px; border: 1px solid #e5e7eb; border-radius: 8px; padding: 8px;">
  </div>
  {{/if}}

  {{#if totpSecret}}
  <div style="text-align: center; margin-bottom: 16px;">
    <p style="font-size: 12px; color: #6b7280;">{{t "two-factor.manual_entry_label"}}</p>
    <code style="font-size: 14px; background: #f3f4f6; padding: 8px 16px; border-radius: 4px; letter-spacing: 2px; user-select: all;">{{totpSecret}}</code>
  </div>
  {{/if}}
</div>

<div style="margin-bottom: 24px;">
  <h2 style="font-size: 16px; margin-bottom: 8px;">{{t "two-factor.setup_step2"}}</h2>
  <p style="font-size: 13px; color: #6b7280; margin-bottom: 16px;">{{t "two-factor.setup_enter_code_instructions"}}</p>

  <form method="POST" action="/interaction/{{interaction.uid}}/two-factor/setup">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <input type="hidden" name="setupMethod" value="totp">

    <div class="form-group">
      <label for="code">{{t "two-factor.totp_code_label"}}</label>
      <input type="text" id="code" name="code" required autofocus
             placeholder="000000" maxlength="6"
             autocomplete="one-time-code" inputmode="numeric"
             pattern="[0-9]{6}"
             style="font-size: 24px; letter-spacing: 4px; text-align: center; max-width: 200px;">
    </div>

    <button type="submit" class="btn-primary">{{t "two-factor.confirm_setup_button"}}</button>
  </form>
</div>

{{#if recoveryCodes}}
<div style="margin-top: 32px; padding: 16px; background: #fffbeb; border: 1px solid #fbbf24; border-radius: 8px;">
  <h2 style="font-size: 16px; margin-bottom: 8px; color: #92400e;">{{t "two-factor.recovery_codes_title"}}</h2>
  <p style="font-size: 13px; color: #92400e; margin-bottom: 12px;">{{t "two-factor.recovery_codes_warning"}}</p>

  <div style="background: white; padding: 12px; border-radius: 4px; font-family: monospace; font-size: 14px; line-height: 1.8; columns: 2; column-gap: 24px;">
    {{#each recoveryCodes}}
    <div>{{this}}</div>
    {{/each}}
  </div>
</div>
{{/if}}

<div class="divider"><span>{{t "two-factor.or_divider"}}</span></div>

<form method="POST" action="/interaction/{{interaction.uid}}/two-factor/setup">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  <input type="hidden" name="setupMethod" value="email">
  <button type="submit" class="btn-secondary">{{t "two-factor.use_email_instead"}}</button>
</form>
