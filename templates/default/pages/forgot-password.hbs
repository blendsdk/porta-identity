{{!-- Forgot password: email input form to request password reset --}}
<h1>{{t "forgot-password.title"}}</h1>
<p class="text-muted mb-4">{{t "forgot-password.description"}}</p>

<form method="POST" action="/{{orgSlug}}/auth/forgot-password">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  {{#if interactionUid}}
    <input type="hidden" name="interaction" value="{{interactionUid}}">
  {{/if}}

  <div class="form-group">
    <label for="email">{{t "forgot-password.email_label"}}</label>
    <input type="email" id="email" name="email" required autofocus placeholder="{{t "forgot-password.email_placeholder"}}">
  </div>

  <button type="submit" class="btn-primary">{{t "forgot-password.submit"}}</button>
</form>

<div class="text-center mt-4">
  <a href="/interaction/{{interactionUid}}">{{t "common.back_to_login"}}</a>
</div>
