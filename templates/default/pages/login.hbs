{{!--
  Login page — renders ONLY the login methods enabled for the current client.

  Context contract (set in src/routes/interactions.ts#showLogin):
    showPassword   : boolean — render the email+password form
    showMagicLink  : boolean — render the magic-link button
    showDivider    : boolean — render the "or" divider (true iff BOTH above)
    emailHint      : string? — login_hint from the OIDC authorize request
    loginMethods   : LoginMethod[] — effective methods (client override or org default)

  Rendering matrix (client metadata → UI):
    ['password','magic_link']  → both forms, divider, magic-link JS copies email
    ['password']               → password form only, no divider, no JS
    ['magic_link']             → standalone magic-link form with its OWN email input, no JS
    []                          → resolver forbids this — we never reach here
--}}
<h1>{{t "login.title"}}</h1>
<p class="text-muted mb-4">{{t "login.subtitle" clientName=interaction.client.clientName}}</p>

{{#if showPassword}}
  {{!-- Password login — email+password+submit. When magic-link is also
       enabled, the shared #email input is also read by the magic-link form
       via the script at the bottom of the page. --}}
  <form method="POST" action="/interaction/{{interaction.uid}}/login">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">

    <div class="form-group">
      <label for="email">{{t "login.email_label"}}</label>
      <input type="email" id="email" name="email" required autofocus
             placeholder="{{t "login.email_placeholder"}}"
             value="{{#if emailHint}}{{emailHint}}{{else}}{{email}}{{/if}}">
    </div>

    <div class="form-group">
      <label for="password">{{t "login.password_label"}}</label>
      <input type="password" id="password" name="password" required
             placeholder="{{t "login.password_placeholder"}}">
    </div>

    {{!-- Forgot-password link only makes sense when password auth is enabled.
         Wrap it in showPassword so magic-link-only clients don't advertise a
         password-recovery flow that enforcePasswordMethod() will block anyway. --}}
    <div class="form-group">
      <a href="/{{orgSlug}}/auth/forgot-password?interaction={{interaction.uid}}"
         class="text-muted" style="font-size: 13px;">{{t "login.forgot_password"}}</a>
    </div>

    <button type="submit" class="btn-primary">{{t "login.submit"}}</button>
  </form>
{{/if}}

{{#if showDivider}}
  <div class="divider"><span>{{t "login.or_divider"}}</span></div>
{{/if}}

{{#if showMagicLink}}
  {{#if showPassword}}
    {{!-- Dual-method mode: the magic-link form has a hidden email field that
         the script below copies from the shared #email input. --}}
    <form method="POST" action="/interaction/{{interaction.uid}}/magic-link">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <input type="hidden" name="email" value="">
      <button type="submit" class="btn-secondary" id="magic-link-btn">
        {{t "login.magic_link_button"}}
      </button>
    </form>
  {{else}}
    {{!-- Magic-link-only mode: there's no password form on the page, so we
         render a standalone email input as a required field. No JS needed. --}}
    <form method="POST" action="/interaction/{{interaction.uid}}/magic-link">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <div class="form-group">
        <label for="email">{{t "login.email_label"}}</label>
        <input type="email" id="email" name="email" required autofocus
               placeholder="{{t "login.email_placeholder"}}"
               value="{{#if emailHint}}{{emailHint}}{{else}}{{email}}{{/if}}">
      </div>

      <button type="submit" class="btn-primary">{{t "login.magic_link_button"}}</button>
    </form>
  {{/if}}
{{/if}}

{{#unless showPassword}}{{#unless showMagicLink}}
  {{!-- No-methods fallback. The resolver guarantees we never reach here
       (resolveLoginMethods returns at least one method), but rendering a
       clear message is safer than a blank page if the contract is ever
       accidentally violated (e.g. a misconfigured template context). --}}
  <div class="alert alert-error" role="alert">
    {{t "errors.no_login_methods_configured"}}
  </div>
{{/unless}}{{/unless}}

{{#if showDivider}}
  {{!-- This script only belongs to the dual-method layout, where the
       magic-link <form> has a hidden email field fed from the shared
       password-form #email input. Single-method layouts don't need it:
       - password-only: no magic-link form to submit
       - magic-link-only: the form has its own real email input --}}
  <script>
    document.getElementById('magic-link-btn').closest('form').addEventListener('submit', function(e) {
      var emailInput = document.getElementById('email');
      this.querySelector('input[name="email"]').value = emailInput.value;
      if (!emailInput.value) { e.preventDefault(); emailInput.focus(); }
    });
  </script>
{{/if}}
