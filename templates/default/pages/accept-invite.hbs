{{!-- Accept invitation: set initial password form --}}
<h1>{{t "invitation.title"}}</h1>
<p class="text-muted mb-4">{{t "invitation.description" orgName=orgName}}</p>

<form method="POST" action="/{{orgSlug}}/accept-invite">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  <input type="hidden" name="token" value="{{token}}">

  <div class="form-group">
    <label>{{t "invitation.email_label"}}</label>
    <input type="email" value="{{email}}" disabled style="background: #f9fafb;">
  </div>

  <div class="form-group">
    <label for="password">{{t "invitation.password_label"}}</label>
    <input type="password" id="password" name="password" required autofocus placeholder="{{t "invitation.password_placeholder"}}" minlength="8">
  </div>

  <div class="form-group">
    <label for="confirmPassword">{{t "invitation.confirm_label"}}</label>
    <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="{{t "invitation.confirm_placeholder"}}" minlength="8">
  </div>

  <button type="submit" class="btn-primary">{{t "invitation.submit"}}</button>
</form>
