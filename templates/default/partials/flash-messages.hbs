{{!-- Flash messages for success/error/info feedback --}}
{{#if flash.error}}
  <div class="flash-error" role="alert">{{flash.error}}</div>
{{/if}}
{{#if flash.success}}
  <div class="flash-success" role="status">{{flash.success}}</div>
{{/if}}
{{#if flash.info}}
  <div class="flash-info" role="status">{{flash.info}}</div>
{{/if}}
